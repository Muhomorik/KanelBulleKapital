<UserControl x:Class="FikaForecast.Wpf.Views.EvaluationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             xmlns:i="http://schemas.microsoft.com/expression/2010/interactivity"
             xmlns:behaviors="clr-namespace:FikaForecast.Wpf.Behaviors"
             xmlns:viewModels="clr-namespace:FikaForecast.Wpf.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance viewModels:EvaluationViewModel, IsDesignTimeCreatable=False}"
             d:DesignHeight="600" d:DesignWidth="1200">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Description -->
        <StackPanel Grid.Row="0" Margin="{StaticResource ff.LabelSpacing}">
            <TextBlock Style="{StaticResource ff.BodyStrongStyle}" Margin="{StaticResource ff.CompactSpacing}">Prompt evaluation</TextBlock>
            <TextBlock Style="{StaticResource ff.CaptionStyle}">Select a past run and evaluate whether its output follows the prompt rules.</TextBlock>
            <TextBlock Style="{StaticResource ff.CaptionStyle}" Margin="{StaticResource ff.CompactSpacing}">
                <Run Text="LLM judge: "/>
                <Run Text="{Binding EvaluationModelName, Mode=OneWay, FallbackValue='(no default model)'}"
                     FontWeight="SemiBold"/>
                <Run Text=" — Runs matching the default model from the last 7 days are pre-checked."/>
            </TextBlock>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Run list -->
            <DockPanel Grid.Column="0" Margin="0,0,12,0">
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="{StaticResource ff.LabelSpacing}">
                    <Button Content="Refresh"
                            Command="{Binding LoadRunsCommand}"
                            Style="{StaticResource ff.ButtonStyle}"/>
                </StackPanel>

                <ListBox ItemsSource="{Binding Runs}"
                         SelectedItem="{Binding SelectedRun}">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type viewModels:EvaluationRunItem}">
                            <Grid Margin="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <CheckBox Grid.Column="0"
                                          IsChecked="{Binding IsChecked}"
                                          VerticalAlignment="Center"
                                          Margin="0,0,8,0"/>

                                <StackPanel Grid.Column="1">
                                    <TextBlock x:Name="TitleText" Style="{StaticResource ff.BodyStrongStyle}">
                                        <Run Text="{Binding Run.DeploymentName, Mode=OneWay}"/>
                                        <Run Text=" — "/>
                                        <Run Text="{Binding Run.Status, Mode=OneWay}"/>
                                    </TextBlock>
                                    <TextBlock x:Name="DetailText" Style="{StaticResource ff.SmallStyle}">
                                        <Run Text="{Binding Run.Timestamp, Mode=OneWay, StringFormat='yyyy-MM-dd HH:mm'}"/>
                                        <Run Text=" | "/>
                                        <Run Text="{Binding Run.TotalTokens, Mode=OneWay, StringFormat='{}{0} tokens'}"/>
                                        <Run Text=" | "/>
                                        <Run Text="{Binding Run.Duration.TotalSeconds, Mode=OneWay, StringFormat='{}{0:F1}s'}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                    <Setter TargetName="TitleText" Property="Foreground" Value="{DynamicResource MahApps.Brushes.Selected.Foreground}"/>
                                    <Setter TargetName="DetailText" Property="Foreground" Value="{DynamicResource MahApps.Brushes.Selected.Foreground}"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <!-- Right panel: detail view or placeholder -->
            <Grid Grid.Column="1">
                <!-- Placeholder when no runs exist -->
                <Border HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource ff.PanelStyle}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Runs.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel HorizontalAlignment="Center" Margin="48,24">
                        <TextBlock FontFamily="Segoe Fluent Icons" FontSize="32"
                                   Foreground="{StaticResource MahApps.Brushes.Gray3}"
                                   HorizontalAlignment="Center" Margin="0,0,0,12"
                                   Text="&#xE823;"/>
                        <TextBlock Style="{StaticResource ff.BodyStrongStyle}"
                                   Foreground="{StaticResource MahApps.Brushes.Gray2}"
                                   HorizontalAlignment="Center" Margin="0,0,0,4"
                                   Text="No runs found"/>
                        <TextBlock Style="{StaticResource ff.CaptionStyle}"
                                   HorizontalAlignment="Center"
                                   Text="No runs found in the database"/>
                    </StackPanel>
                </Border>

                <!-- Content panel (when runs exist) -->
                <Border>
                    <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource ff.PanelStyle}">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Runs.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>

                    <Grid>
                        <!-- Placeholder when no run is selected -->
                        <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center"
                                   Text="Check runs to evaluate, then click Evaluate checked">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource ff.BodyStyle}">
                                    <Setter Property="Foreground" Value="{StaticResource MahApps.Brushes.Gray3}"/>
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedRun}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- Selected run detail + evaluation -->
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedRun}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>

                            <!-- Run summary -->
                            <TextBlock Grid.Row="0" Style="{StaticResource ff.BodyLargeStyle}"
                                       FontWeight="SemiBold" Margin="0,0,0,4"
                                       DataContext="{Binding SelectedRun.Run}">
                                <Run Text="{Binding DeploymentName, Mode=OneWay}"/>
                                <Run Text=" — "/>
                                <Run Text="{Binding PromptName, Mode=OneWay}"/>
                            </TextBlock>

                            <TextBlock Grid.Row="1" Style="{StaticResource ff.CaptionStyle}"
                                       Margin="0,0,0,12"
                                       DataContext="{Binding SelectedRun.Run}">
                                <Run Text="{Binding Timestamp, Mode=OneWay, StringFormat='yyyy-MM-dd HH:mm:ss'}"/>
                                <Run Text=" | Input: "/>
                                <Run Text="{Binding InputTokens, Mode=OneWay}"/>
                                <Run Text=" | Output: "/>
                                <Run Text="{Binding OutputTokens, Mode=OneWay}"/>
                                <Run Text=" | Total: "/>
                                <Run Text="{Binding TotalTokens, Mode=OneWay}"/>
                                <Run Text=" | "/>
                                <Run Text="{Binding Duration.TotalSeconds, Mode=OneWay, StringFormat='{}{0:F1}s'}"/>
                            </TextBlock>

                            <!-- Evaluate button + status -->
                            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="{StaticResource ff.LabelSpacing}">
                                <Button Content="Evaluate checked"
                                        Command="{Binding EvaluateCommand}"
                                        Style="{StaticResource ff.ButtonAccentStyle}"
                                        Margin="0,0,12,0"/>
                                <mah:ProgressRing IsActive="{Binding IsEvaluating}"
                                                  Width="24" Height="24"
                                                  Margin="0,0,8,0"/>
                            </StackPanel>

                            <!-- Status message -->
                            <TextBlock Grid.Row="3" Margin="{StaticResource ff.LabelSpacing}"
                                       Text="{Binding StatusMessage}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource ff.CaptionStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsStatusError}" Value="True">
                                                <Setter Property="Foreground" Value="{DynamicResource ff.ErrorBrush}"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <!-- Evaluation result -->
                            <wv2:WebView2 Grid.Row="4">
                                <wv2:WebView2.Style>
                                    <Style TargetType="FrameworkElement">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding EvaluationResult}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </wv2:WebView2.Style>
                                <i:Interaction.Behaviors>
                                    <behaviors:WebView2HtmlBehavior Markdown="{Binding EvaluationResult, Mode=OneWay}"/>
                                </i:Interaction.Behaviors>
                            </wv2:WebView2>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
