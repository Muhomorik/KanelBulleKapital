<UserControl x:Class="FikaForecast.Wpf.Views.ComparisonView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             xmlns:i="http://schemas.microsoft.com/expression/2010/interactivity"
             xmlns:behaviors="clr-namespace:FikaForecast.Wpf.Behaviors"
             xmlns:viewModels="clr-namespace:FikaForecast.Wpf.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance viewModels:ComparisonViewModel, IsDesignTimeCreatable=False}"
             d:DesignHeight="600" d:DesignWidth="1200">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Configuration warning banner -->
        <Border Grid.Row="0"
                Background="{StaticResource ff.WarningBackgroundBrush}"
                BorderBrush="{StaticResource ff.WarningBorderBrush}"
                BorderThickness="1"
                CornerRadius="4" Padding="12" Margin="0,0,0,12"
                Visibility="{Binding IsConfigured, Converter={dxmvvm:BooleanToVisibilityConverter Inverse=True}}">
            <TextBlock Text="{Binding ConfigurationMessage}"
                       TextWrapping="Wrap"
                       Foreground="{StaticResource ff.WarningForegroundBrush}"
                       FontSize="12"/>
        </Border>

        <!-- Description -->
        <StackPanel Grid.Row="1" Margin="0,0,0,8">
            <TextBlock Style="{StaticResource ff.BodyStrongStyle}" Margin="{StaticResource ff.CompactSpacing}">How it works</TextBlock>
            <TextBlock Style="{StaticResource ff.CaptionStyle}">Prompt  &#x2192;  Azure AI Foundry  &#x2192;  Bing Grounding (live news search)  &#x2192;  Structured market brief</TextBlock>
            <TextBlock Style="{StaticResource ff.CaptionStyle}" Margin="{StaticResource ff.CompactSpacing}">Compare models to see which catches more events, follows instructions better, and costs less per run.</TextBlock>
        </StackPanel>

        <!-- Controls -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,12">
            <ComboBox x:Name="ModelSelector"
                      ItemsSource="{Binding AvailableModels}"
                      SelectedItem="{Binding SelectedModel}"
                      DisplayMemberPath="DisplayName"
                      Width="200"
                      Margin="0,0,8,0"
                      mah:TextBoxHelper.Watermark="Select model..."/>
            <Button Content="Run single"
                    Command="{Binding RunSingleCommand}"
                    CommandParameter="{Binding SelectedItem, ElementName=ModelSelector}"
                    Style="{StaticResource ff.ButtonStyle}"
                    Margin="0,0,8,0"/>
            <Button Content="Compare all"
                    Command="{Binding RunComparisonCommand}"
                    Style="{StaticResource ff.ButtonAccentStyle}"
                    Margin="0,0,8,0"/>
            <Button Content="Clear"
                    Command="{Binding ClearResultsCommand}"
                    Style="{StaticResource ff.ButtonFlatStyle}"/>
            <mah:ProgressRing IsActive="{Binding IsRunning}"
                              Width="24" Height="24"
                              Margin="12,0,0,0"/>
        </StackPanel>

        <!-- Status -->
        <TextBlock Grid.Row="3"
                   Text="{Binding StatusMessage}"
                   TextWrapping="Wrap"
                   Margin="0,0,0,12">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Foreground" Value="{StaticResource MahApps.Brushes.Gray2}"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsStatusError}" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource ff.ErrorBrush}"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <!-- Results side-by-side -->
        <Grid Grid.Row="4">
            <!-- Empty state placeholder -->
            <Border HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource ff.PanelStyle}">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Results.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel HorizontalAlignment="Center" Margin="48,24">
                    <TextBlock FontFamily="Segoe Fluent Icons" FontSize="32"
                               Foreground="{StaticResource MahApps.Brushes.Gray3}"
                               HorizontalAlignment="Center" Margin="0,0,0,12"
                               Text="&#xE895;"/>
                    <TextBlock Style="{StaticResource ff.BodyStrongStyle}"
                               Foreground="{StaticResource MahApps.Brushes.Gray2}"
                               HorizontalAlignment="Center" Margin="0,0,0,4"
                               Text="Results will appear here"/>
                    <TextBlock Style="{StaticResource ff.CaptionStyle}"
                               HorizontalAlignment="Center"
                               Text="Select a model and run a comparison to begin"/>
                </StackPanel>
            </Border>

            <!-- Result cards -->
            <ItemsControl ItemsSource="{Binding Results}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="2"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource ff.PanelControlStyle}" Margin="4" Padding="12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Model header -->
                                <TextBlock Grid.Row="0"
                                           Style="{StaticResource ff.BodyStrongStyle}"
                                           Margin="0,0,0,4">
                                    <Run Text="{Binding DeploymentName, Mode=OneWay}"/>
                                </TextBlock>

                                <!-- Stats -->
                                <TextBlock Grid.Row="1"
                                           Style="{StaticResource ff.CaptionStyle}"
                                           Margin="0,0,0,8">
                                    <Run Text="{Binding TotalTokens, Mode=OneWay, StringFormat='{}Tokens: {0}'}"/>
                                    <Run Text=" | "/>
                                    <Run Text="{Binding Duration.TotalSeconds, Mode=OneWay, StringFormat='{}{0:F1}s'}"/>
                                    <Run Text=" | "/>
                                    <Run Text="{Binding Status, Mode=OneWay}"/>
                                </TextBlock>

                                <!-- Brief output -->
                                <wv2:WebView2 Grid.Row="2">
                                    <i:Interaction.Behaviors>
                                        <behaviors:WebView2HtmlBehavior Markdown="{Binding RawMarkdownOutput, Mode=OneWay}"/>
                                    </i:Interaction.Behaviors>
                                </wv2:WebView2>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </Grid>
</UserControl>
