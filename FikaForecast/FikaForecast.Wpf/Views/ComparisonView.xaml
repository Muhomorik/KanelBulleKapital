<UserControl x:Class="FikaForecast.Wpf.Views.ComparisonView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="1200">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Configuration warning banner -->
        <Border Grid.Row="0"
                Background="#FFF3CD" BorderBrush="#FFECB5" BorderThickness="1"
                CornerRadius="4" Padding="12" Margin="0,0,0,12"
                Visibility="{Binding IsConfigured, Converter={dxmvvm:BooleanToVisibilityConverter Inverse=True}}">
            <TextBlock Text="{Binding ConfigurationMessage}"
                       TextWrapping="Wrap"
                       FontFamily="Cascadia Code, Consolas"
                       FontSize="12"/>
        </Border>

        <!-- Description -->
        <StackPanel Grid.Row="1" Margin="0,0,0,8">
            <TextBlock FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4">How it works</TextBlock>
            <TextBlock Foreground="Gray" FontSize="12">Prompt  &#x2192;  Azure AI Foundry  &#x2192;  Bing Grounding (live news search)  &#x2192;  Structured market brief</TextBlock>
            <TextBlock Foreground="Gray" FontSize="12" Margin="0,4,0,0">Compare models to see which catches more events, follows instructions better, and costs less per run.</TextBlock>
        </StackPanel>

        <!-- Controls -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,12">
            <ComboBox x:Name="ModelSelector"
                      ItemsSource="{Binding AvailableModels}"
                      DisplayMemberPath="DisplayName"
                      Width="200"
                      Margin="0,0,8,0"
                      mah:TextBoxHelper.Watermark="Select model..."/>
            <Button Content="Run Single"
                    Command="{Binding RunSingleCommand}"
                    CommandParameter="{Binding SelectedItem, ElementName=ModelSelector}"
                    Margin="0,0,8,0"
                    Padding="16,6"/>
            <Button Content="Compare All"
                    Command="{Binding RunComparisonCommand}"
                    Padding="16,6"/>
            <mah:ProgressRing IsActive="{Binding IsRunning}"
                              Width="24" Height="24"
                              Margin="12,0,0,0"/>
        </StackPanel>

        <!-- Status -->
        <TextBlock Grid.Row="3"
                   Text="{Binding StatusMessage}"
                   Foreground="Gray"
                   Margin="0,0,0,12"/>

        <!-- Results side-by-side -->
        <ItemsControl Grid.Row="4" ItemsSource="{Binding Results}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="2"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="Gray" BorderThickness="1"
                            CornerRadius="4" Margin="4" Padding="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Model header -->
                            <TextBlock Grid.Row="0"
                                       FontSize="16" FontWeight="SemiBold"
                                       Margin="0,0,0,4">
                                <Run Text="{Binding DeploymentName, Mode=OneWay}"/>
                            </TextBlock>

                            <!-- Stats -->
                            <TextBlock Grid.Row="1" Foreground="Gray" Margin="0,0,0,8">
                                <Run Text="{Binding TotalTokens, Mode=OneWay, StringFormat='{}Tokens: {0}'}"/>
                                <Run Text=" | "/>
                                <Run Text="{Binding Duration.TotalSeconds, Mode=OneWay, StringFormat='{}{0:F1}s'}"/>
                                <Run Text=" | "/>
                                <Run Text="{Binding Status, Mode=OneWay}"/>
                            </TextBlock>

                            <!-- Brief output -->
                            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                                <TextBlock Text="{Binding RawMarkdownOutput, Mode=OneWay}"
                                           TextWrapping="Wrap"
                                           FontFamily="Cascadia Code, Consolas"/>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</UserControl>
