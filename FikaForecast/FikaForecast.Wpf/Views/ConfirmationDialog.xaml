<mah:MetroWindow x:Class="FikaForecast.Wpf.Views.ConfirmationDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 Title="Confirm"
                 Width="360"
                 SizeToContent="Height"
                 ResizeMode="NoResize"
                 WindowStartupLocation="CenterOwner"
                 ShowInTaskbar="False"
                 GlowBrush="{DynamicResource MahApps.Brushes.Accent}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{Binding Message, Mode=OneWay}"
                   TextWrapping="Wrap"
                   VerticalAlignment="Center"
                   FontSize="13"
                   LineHeight="18"
                   Foreground="{DynamicResource MahApps.Brushes.Text}"/>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="Delete"
                    Click="DeleteButton_Click"
                    Style="{DynamicResource MahApps.Styles.Button}"
                    Background="#FFE51400"
                    Foreground="White"
                    Padding="16,6"
                    FontWeight="SemiBold"
                    MinWidth="80"
                    mah:ControlsHelper.MouseOverBorderBrush="#FFBF1400">
                <Button.Resources>
                    <SolidColorBrush x:Key="MahApps.Brushes.Button.ForegroundPointerOver" Color="White"/>
                    <SolidColorBrush x:Key="MahApps.Brushes.Button.ForegroundPressed" Color="White"/>
                </Button.Resources>
            </Button>
            <Button Content="Cancel"
                    Click="CancelButton_Click"
                    Style="{DynamicResource MahApps.Styles.Button}"
                    Padding="16,6"
                    Margin="6,0,0,0"
                    MinWidth="80"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</mah:MetroWindow>
