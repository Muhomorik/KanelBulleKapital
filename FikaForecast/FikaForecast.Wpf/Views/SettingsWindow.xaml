<mah:MetroWindow x:Class="FikaForecast.Wpf.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
        xmlns:viewModels="clr-namespace:FikaForecast.Wpf.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance viewModels:SettingsViewModel, IsDesignTimeCreatable=True}"
        Title="Settings" Height="480" Width="640"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <dxmvvm:Interaction.Behaviors>
        <dxmvvm:CurrentWindowService/>
    </dxmvvm:Interaction.Behaviors>
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Restart warning (models tab only — prompt changes take effect immediately) -->
        <Border Grid.Row="1"
                Visibility="{Binding IsRestartWarningVisible, Converter={dxmvvm:BooleanToVisibilityConverter}}"
                Background="{StaticResource ff.WarningBackgroundBrush}"
                BorderBrush="{StaticResource ff.WarningBorderBrush}"
                BorderThickness="1"
                CornerRadius="4" Padding="12"
                Margin="{StaticResource ff.SubsectionSpacing}">
            <TextBlock Text="&#x26A0;  Changes take effect after restarting the application."
                       Foreground="{StaticResource ff.WarningForegroundBrush}"
                       Style="{StaticResource ff.CaptionStyle}"/>
        </Border>

        <!-- Tabbed content -->
        <mah:MetroTabControl Grid.Row="2"
                             mah:TabControlHelper.Underlined="SelectedTabItem"
                             SelectedIndex="{Binding SelectedTabIndex}"
                             Margin="{StaticResource ff.SubsectionSpacing}">

            <!-- Models Tab -->
            <TabItem Header="Models" Padding="12,6">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Select which models appear in the Comparison view:"
                               Style="{StaticResource ff.CaptionStyle}"
                               Margin="{StaticResource ff.LabelSpacing}"/>

                    <!-- Model checkboxes -->
                    <ItemsControl Grid.Row="1" ItemsSource="{Binding ModelItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type viewModels:ModelSettingItem}">
                                <CheckBox IsChecked="{Binding IsEnabled}"
                                          Margin="{StaticResource ff.CompactSpacing}">
                                    <TextBlock>
                                        <Run Text="{Binding Model.DisplayName, Mode=OneWay}"/>
                                        <Run Text=" (" Foreground="{StaticResource MahApps.Brushes.Gray3}"/><Run Text="{Binding Model.ModelId, Mode=OneWay}" Foreground="{StaticResource MahApps.Brushes.Gray3}"/><Run Text=")" Foreground="{StaticResource MahApps.Brushes.Gray3}"/>
                                    </TextBlock>
                                </CheckBox>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Default model selector -->
                    <StackPanel Grid.Row="2" Margin="0,12,0,0">
                        <TextBlock Text="Default model (pre-selected at startup):"
                                   Style="{StaticResource ff.CaptionStyle}"
                                   Margin="{StaticResource ff.CompactSpacing}"/>
                        <ComboBox ItemsSource="{Binding ModelItems}"
                                  SelectedValue="{Binding DefaultModel}"
                                  SelectedValuePath="Model"
                                  DisplayMemberPath="Model.DisplayName"
                                  Width="300" HorizontalAlignment="Left"
                                  mah:TextBoxHelper.Watermark="None"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Prompts Tab -->
            <TabItem Header="Prompts" Padding="12,6">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Prompt selector -->
                    <StackPanel Grid.Row="0">
                        <TextBlock Text="Select a prompt to edit:"
                                   Style="{StaticResource ff.CaptionStyle}"
                                   Margin="{StaticResource ff.LabelSpacing}"/>
                        <ComboBox ItemsSource="{Binding PromptItems}"
                                  SelectedItem="{Binding SelectedPrompt}"
                                  DisplayMemberPath="DisplayName"
                                  Width="300" HorizontalAlignment="Left"/>
                    </StackPanel>

                    <!-- Prompt name (read-only) -->
                    <TextBlock Grid.Row="1"
                               Style="{StaticResource ff.SmallStyle}"
                               Margin="{StaticResource ff.ItemSpacing}">
                        <Run Text="Name: "/>
                        <Run Text="{Binding SelectedPrompt.DisplayName, Mode=OneWay}"/>
                    </TextBlock>

                    <!-- Prompt body editor -->
                    <TextBox Grid.Row="2"
                             Text="{Binding SelectedPrompt.Body, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True"
                             AcceptsTab="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             FontFamily="Consolas"
                             FontSize="12"
                             Margin="{StaticResource ff.ItemSpacing}"
                             mah:TextBoxHelper.Watermark="Enter prompt text..."/>

                    <!-- Reset + dirty indicator -->
                    <StackPanel Grid.Row="3" Orientation="Horizontal"
                                Margin="{StaticResource ff.ItemSpacing}">
                        <Button Content="Reset to Default"
                                Command="{Binding ResetPromptCommand}"
                                Style="{StaticResource ff.ButtonFlatStyle}"/>
                        <TextBlock Text="  Unsaved changes"
                                   Style="{StaticResource ff.SmallStyle}"
                                   Foreground="{StaticResource ff.WarningBrush}"
                                   VerticalAlignment="Center"
                                   Visibility="{Binding SelectedPrompt.IsDirty, Converter={dxmvvm:BooleanToVisibilityConverter}}"/>
                    </StackPanel>
                </Grid>
            </TabItem>
        </mah:MetroTabControl>

        <!-- Settings file path -->
        <TextBlock Grid.Row="3"
                   Style="{StaticResource ff.SmallStyle}"
                   Margin="{StaticResource ff.SubsectionSpacing}">
            <Run Text="Settings file: "/>
            <Run Text="{Binding SettingsFilePath, Mode=OneWay}"/>
        </TextBlock>

        <!-- Footer buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Save"
                    Command="{Binding SaveCommand}"
                    Style="{StaticResource ff.ButtonAccentStyle}"
                    Margin="0,0,8,0"/>
            <Button Content="Close"
                    Command="{Binding CloseCommand}"
                    Style="{StaticResource ff.ButtonStyle}"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</mah:MetroWindow>
