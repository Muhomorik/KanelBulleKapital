<mah:MetroWindow x:Class="FikaForecast.Wpf.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
        xmlns:viewModels="clr-namespace:FikaForecast.Wpf.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance viewModels:SettingsViewModel, IsDesignTimeCreatable=True}"
        Title="Settings" Height="480" Width="640"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <dxmvvm:Interaction.Behaviors>
        <dxmvvm:CurrentWindowService/>
    </dxmvvm:Interaction.Behaviors>
    <Grid Margin="16,8,16,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Tabbed content -->
        <mah:MetroTabControl Grid.Row="0"
                             mah:TabControlHelper.Underlined="SelectedTabItem"
                             SelectedIndex="{Binding SelectedTabIndex}">

            <!-- Models Tab -->
            <TabItem Header="Models" Padding="12,6">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,8,0,0">
                    <StackPanel>
                        <!-- Enabled models card -->
                        <Border Style="{StaticResource ff.PanelControlStyle}">
                            <StackPanel>
                                <TextBlock Text="Enabled models"
                                           Style="{StaticResource ff.SubheaderStyle}"
                                           Margin="{StaticResource ff.LabelSpacing}"/>
                                <TextBlock Text="Select which models appear in the Comparison view."
                                           Style="{StaticResource ff.CaptionStyle}"
                                           Margin="{StaticResource ff.LabelSpacing}"/>
                                <ItemsControl ItemsSource="{Binding ModelItems}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type viewModels:ModelSettingItem}">
                                            <CheckBox IsChecked="{Binding IsEnabled}"
                                                      Margin="{StaticResource ff.CompactSpacing}">
                                                <TextBlock>
                                                    <Run Text="{Binding Model.DisplayName, Mode=OneWay}"/>
                                                    <Run Text=" (" Foreground="{StaticResource MahApps.Brushes.Gray3}"/><Run Text="{Binding Model.ModelId, Mode=OneWay}" Foreground="{StaticResource MahApps.Brushes.Gray3}"/><Run Text=")" Foreground="{StaticResource MahApps.Brushes.Gray3}"/>
                                                </TextBlock>
                                            </CheckBox>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- Default model card -->
                        <Border Style="{StaticResource ff.PanelControlStyle}"
                                Margin="{StaticResource ff.ItemSpacing}">
                            <StackPanel>
                                <TextBlock Text="Default model"
                                           Style="{StaticResource ff.SubheaderStyle}"
                                           Margin="{StaticResource ff.LabelSpacing}"/>
                                <TextBlock Text="Pre-selected model at startup."
                                           Style="{StaticResource ff.CaptionStyle}"
                                           Margin="{StaticResource ff.LabelSpacing}"/>
                                <ComboBox ItemsSource="{Binding ModelItems}"
                                          SelectedValue="{Binding DefaultModel}"
                                          SelectedValuePath="Model"
                                          DisplayMemberPath="Model.DisplayName"
                                          HorizontalAlignment="Stretch"
                                          mah:TextBoxHelper.Watermark="None"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Prompts Tab -->
            <TabItem Header="Prompts" Padding="12,6">
                <Grid Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Prompt selector card -->
                    <Border Grid.Row="0" Style="{StaticResource ff.PanelControlStyle}">
                        <StackPanel>
                            <DockPanel Margin="{StaticResource ff.LabelSpacing}">
                                <Button DockPanel.Dock="Right"
                                        Content="Reset to Default"
                                        Command="{Binding ResetPromptCommand}"
                                        Style="{StaticResource ff.ButtonFlatStyle}"
                                        Padding="12,4"
                                        Margin="8,0,0,0"/>
                                <TextBlock Text="Active prompt"
                                           Style="{StaticResource ff.SubheaderStyle}"
                                           VerticalAlignment="Center"/>
                            </DockPanel>
                            <ComboBox ItemsSource="{Binding PromptItems}"
                                      SelectedItem="{Binding SelectedPrompt}"
                                      DisplayMemberPath="DisplayName"
                                      HorizontalAlignment="Stretch"/>
                        </StackPanel>
                    </Border>

                    <!-- Prompt editor card -->
                    <Border Grid.Row="1" Style="{StaticResource ff.PanelControlStyle}"
                            Margin="{StaticResource ff.ItemSpacing}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <DockPanel Grid.Row="0" Margin="{StaticResource ff.LabelSpacing}">
                                <TextBlock DockPanel.Dock="Right"
                                           Text="Unsaved changes"
                                           Style="{StaticResource ff.SmallStyle}"
                                           Foreground="{StaticResource ff.WarningBrush}"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding SelectedPrompt.IsDirty, Converter={dxmvvm:BooleanToVisibilityConverter}}"/>
                                <TextBlock Style="{StaticResource ff.SubheaderStyle}"
                                           VerticalAlignment="Center">
                                    <Run Text="Prompt body"/>
                                    <Run Text=" — "/>
                                    <Run Text="{Binding SelectedPrompt.DisplayName, Mode=OneWay}"
                                         FontWeight="Normal"
                                         Foreground="{StaticResource MahApps.Brushes.Gray3}"/>
                                </TextBlock>
                            </DockPanel>

                            <TextBox Grid.Row="1"
                                     Text="{Binding SelectedPrompt.Body, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True"
                                     AcceptsTab="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     FontFamily="Consolas"
                                     FontSize="12"/>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
        </mah:MetroTabControl>

        <!-- Restart warning -->
        <Border Grid.Row="1"
                Background="{StaticResource ff.WarningBackgroundBrush}"
                BorderBrush="{StaticResource ff.WarningBorderBrush}"
                BorderThickness="1"
                CornerRadius="4" Padding="8,6"
                Margin="0,8,0,0">
            <TextBlock Text="&#x26A0;  Changes take effect after restarting the application."
                       Foreground="{StaticResource ff.WarningForegroundBrush}"
                       Style="{StaticResource ff.CaptionStyle}"/>
        </Border>

        <!-- Footer: file path + buttons -->
        <DockPanel Grid.Row="2" Margin="0,8,0,0">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Content="Save"
                        Command="{Binding SaveCommand}"
                        Style="{StaticResource ff.ButtonAccentStyle}"
                        Margin="0,0,8,0"/>
                <Button Content="Close"
                        Command="{Binding CloseCommand}"
                        Style="{StaticResource ff.ButtonStyle}"
                        IsCancel="True"/>
            </StackPanel>
            <TextBlock Style="{StaticResource ff.SmallStyle}"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis">
                <Run Text="Settings file: "/>
                <Run Text="{Binding SettingsFilePath, Mode=OneWay}"/>
            </TextBlock>
        </DockPanel>
    </Grid>
</mah:MetroWindow>
