<UserControl x:Class="FikaForecast.Wpf.Views.HistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             xmlns:i="http://schemas.microsoft.com/expression/2010/interactivity"
             xmlns:behaviors="clr-namespace:FikaForecast.Wpf.Behaviors"
             xmlns:viewModels="clr-namespace:FikaForecast.Wpf.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance viewModels:HistoryViewModel, IsDesignTimeCreatable=False}"
             d:DesignHeight="600" d:DesignWidth="1200">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Description -->
        <StackPanel Grid.Row="0" Margin="{StaticResource ff.LabelSpacing}">
            <TextBlock Style="{StaticResource ff.BodyStrongStyle}" Margin="{StaticResource ff.CompactSpacing}">Run history</TextBlock>
            <TextBlock Style="{StaticResource ff.CaptionStyle}">Every run is saved with token counts (input / output / total), duration, and the full brief.</TextBlock>
            <TextBlock Style="{StaticResource ff.CaptionStyle}" Margin="{StaticResource ff.CompactSpacing}">Track cost per model over time and check if a cheaper model produces comparable quality.</TextBlock>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Run list -->
            <DockPanel Grid.Column="0" Margin="0,0,16,0">
                <Grid DockPanel.Dock="Top" Margin="{StaticResource ff.LabelSpacing}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0"
                            Content="Refresh"
                            Style="{StaticResource ff.ButtonAccentStyle}"
                            Command="{Binding LoadRunsCommand}"/>
                    <Button Grid.Column="2"
                            Content="Clear filter"
                            Style="{StaticResource ff.ButtonStyle}"
                            Command="{Binding ClearFilterCommand}"/>
                    <Button Grid.Column="4"
                            Content="Delete all"
                            Style="{StaticResource ff.ButtonStyle}"
                            Command="{Binding DeleteAllRunsCommand}"
                            Foreground="{StaticResource ff.ErrorBrush}"/>
                </Grid>

                <ListBox ItemsSource="{Binding Runs}"
                         SelectedItem="{Binding SelectedRun}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock x:Name="PrimaryText" Style="{StaticResource ff.BodyStrongStyle}">
                                        <Run Text="{Binding DeploymentName, Mode=OneWay}"/>
                                        <Run Text=" — "/>
                                        <Run Text="{Binding Status, Mode=OneWay}"/>
                                    </TextBlock>
                                    <TextBlock x:Name="SecondaryText" Style="{StaticResource ff.SmallStyle}">
                                        <Run Text="{Binding Timestamp, Mode=OneWay, StringFormat='yyyy-MM-dd HH:mm'}"/>
                                        <Run Text=" | "/>
                                        <Run Text="{Binding TotalTokens, Mode=OneWay, StringFormat='{}{0} tokens'}"/>
                                        <Run Text=" | "/>
                                        <Run Text="{Binding Duration.TotalSeconds, Mode=OneWay, StringFormat='{}{0:F1}s'}"/>
                                    </TextBlock>
                                </StackPanel>

                                <Button Grid.Column="1"
                                        Style="{StaticResource ff.ButtonDeleteIconStyle}"
                                        Command="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=DataContext.DeleteRunCommand}"
                                        CommandParameter="{Binding}"
                                        Margin="8,0,0,0"
                                        ToolTip="Delete this run">
                                    <TextBlock FontFamily="Segoe Fluent Icons" FontSize="12" Text="&#xE711;"/>
                                </Button>
                            </Grid>

                            <!-- IsSelected: switch text to contrast color on accent background (MUST be last trigger) -->
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                    <Setter TargetName="PrimaryText" Property="Foreground" Value="{DynamicResource MahApps.Brushes.Selected.Foreground}"/>
                                    <Setter TargetName="SecondaryText" Property="Foreground" Value="{DynamicResource MahApps.Brushes.Selected.Foreground}"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <!-- Right panel: detail view or placeholder -->
            <Grid Grid.Column="1">
                <!-- Placeholder when no history records exist -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Runs.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="No history records"
                               Style="{StaticResource ff.BodyLargeStyle}"
                               Foreground="{StaticResource MahApps.Brushes.Gray3}"
                               HorizontalAlignment="Center"
                               Margin="{StaticResource ff.ItemSpacing}"/>
                    <TextBlock Text="Click Refresh to load run history"
                               Style="{StaticResource ff.CaptionStyle}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Selected run detail or empty selection placeholder -->
                <Border>
                    <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource ff.PanelControlStyle}">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Runs.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>

                    <Grid>
                        <!-- Placeholder when no run is selected -->
                        <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center"
                                   Foreground="{StaticResource MahApps.Brushes.Gray3}"
                                   Text="Select a run to view details">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource ff.BodyStyle}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedRun}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- Selected run details -->
                        <Grid DataContext="{Binding SelectedRun}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>

                            <TextBlock Grid.Row="0" Style="{StaticResource ff.TitleStyle}" Margin="{StaticResource ff.CompactSpacing}">
                                <Run Text="{Binding DeploymentName, Mode=OneWay}"/>
                                <Run Text=" — "/>
                                <Run Text="{Binding PromptName, Mode=OneWay}"/>
                            </TextBlock>

                            <TextBlock Grid.Row="1" Style="{StaticResource ff.CaptionStyle}" Margin="{StaticResource ff.LabelSpacing}">
                                <Run Text="{Binding Timestamp, Mode=OneWay, StringFormat='yyyy-MM-dd HH:mm:ss'}"/>
                                <Run Text=" | Input: "/>
                                <Run Text="{Binding InputTokens, Mode=OneWay}"/>
                                <Run Text=" | Output: "/>
                                <Run Text="{Binding OutputTokens, Mode=OneWay}"/>
                                <Run Text=" | Total: "/>
                                <Run Text="{Binding TotalTokens, Mode=OneWay}"/>
                                <Run Text=" | "/>
                                <Run Text="{Binding Duration.TotalSeconds, Mode=OneWay, StringFormat='{}{0:F1}s'}"/>
                            </TextBlock>

                            <wv2:WebView2 Grid.Row="2">
                                <i:Interaction.Behaviors>
                                    <behaviors:WebView2HtmlBehavior Markdown="{Binding RawMarkdownOutput, Mode=OneWay}"/>
                                </i:Interaction.Behaviors>
                            </wv2:WebView2>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
