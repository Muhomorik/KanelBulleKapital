<UserControl x:Class="FikaForecast.Wpf.Views.HistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="1200">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Description -->
        <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4">Run history</TextBlock>
            <TextBlock Foreground="Gray" FontSize="12">Every run is saved with token counts (input / output / total), duration, and the full brief.</TextBlock>
            <TextBlock Foreground="Gray" FontSize="12" Margin="0,4,0,0">Track cost per model over time and check if a cheaper model produces comparable quality.</TextBlock>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Run list -->
            <DockPanel Grid.Column="0" Margin="0,0,12,0">
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                    <Button Content="Refresh"
                            Command="{Binding LoadRunsCommand}"
                            Padding="12,6"
                            Margin="0,0,8,0"/>
                    <Button Content="Clear Filter"
                            Command="{Binding ClearFilterCommand}"
                            Padding="12,6"/>
                </StackPanel>

                <ListBox ItemsSource="{Binding Runs}"
                         SelectedItem="{Binding SelectedRun}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="4">
                                <TextBlock FontWeight="SemiBold">
                                    <Run Text="{Binding DeploymentName, Mode=OneWay}"/>
                                    <Run Text=" — "/>
                                    <Run Text="{Binding Status, Mode=OneWay}"/>
                                </TextBlock>
                                <TextBlock Foreground="Gray" FontSize="11">
                                    <Run Text="{Binding Timestamp, Mode=OneWay, StringFormat='yyyy-MM-dd HH:mm'}"/>
                                    <Run Text=" | "/>
                                    <Run Text="{Binding TotalTokens, Mode=OneWay, StringFormat='{}{0} tokens'}"/>
                                    <Run Text=" | "/>
                                    <Run Text="{Binding Duration.TotalSeconds, Mode=OneWay, StringFormat='{}{0:F1}s'}"/>
                                </TextBlock>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <!-- Selected run detail -->
            <Border Grid.Column="1" BorderBrush="Gray" BorderThickness="1"
                    CornerRadius="4" Padding="12">
                <Grid DataContext="{Binding SelectedRun}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,4">
                        <Run Text="{Binding DeploymentName, Mode=OneWay}"/>
                        <Run Text=" — "/>
                        <Run Text="{Binding PromptName, Mode=OneWay}"/>
                    </TextBlock>

                    <TextBlock Grid.Row="1" Foreground="Gray" Margin="0,0,0,12">
                        <Run Text="{Binding Timestamp, Mode=OneWay, StringFormat='yyyy-MM-dd HH:mm:ss'}"/>
                        <Run Text=" | Input: "/>
                        <Run Text="{Binding InputTokens, Mode=OneWay}"/>
                        <Run Text=" | Output: "/>
                        <Run Text="{Binding OutputTokens, Mode=OneWay}"/>
                        <Run Text=" | Total: "/>
                        <Run Text="{Binding TotalTokens, Mode=OneWay}"/>
                        <Run Text=" | "/>
                        <Run Text="{Binding Duration.TotalSeconds, Mode=OneWay, StringFormat='{}{0:F1}s'}"/>
                    </TextBlock>

                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <TextBlock Text="{Binding RawMarkdownOutput, Mode=OneWay}"
                                   TextWrapping="Wrap"
                                   FontFamily="Cascadia Code, Consolas"/>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
