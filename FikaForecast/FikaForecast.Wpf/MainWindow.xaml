<mah:MetroWindow x:Class="FikaForecast.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        xmlns:views="clr-namespace:FikaForecast.Wpf.Views"
        mc:Ignorable="d"
        Title="FikaForecast" Height="768" Width="1280"
        WindowStartupLocation="CenterScreen">
    <mah:MetroTabControl mah:TabControlHelper.Underlined="SelectedTabItem">

        <TabItem Header="&#x2194;  Comparison" Padding="16,8">
            <views:ComparisonView x:Name="ComparisonView" />
        </TabItem>
        <TabItem Header="&#x1F552;  History" Padding="16,8">
            <views:HistoryView x:Name="HistoryView" />
        </TabItem>
    </mah:MetroTabControl>
</mah:MetroWindow>
